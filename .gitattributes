# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Keep Windows command scripts CRLF for native execution.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should stay LF for Linux/macOS/WSL compatibility.
*.sh text eol=lf

# Source and config files: enforce LF consistently.
*.java text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary assets: never modify line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.war binary
*.class binary
